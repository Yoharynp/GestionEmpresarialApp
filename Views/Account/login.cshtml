@{ Layout = null;}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión</title>
    <link rel="stylesheet" href="/css/site.css">
    <link rel="stylesheet" href="/css/login.css">
</head>
<body>
    <div class="main" >
        <div class="main-left">
            <h1>Sistema de Control de Acceso</h1>
            <p>Ingrese sus credenciales</p>
            <form method="post" action="/Account/Login">
                <div class="form-group">
                    <label for="username">Usuario</label>
                    <input type="text" id="username" name="username" required placeholder="Ingrese su usuario">
                </div>
                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" required placeholder="*************">
                </div>
                <button type="submit">Iniciar Sesión</button>
            </form>
        </div>
        <div class="main-right">
            <h1>Control de Acceso Empresarial</h1>
            <p class="main-right-subtitle" >Sistema integral de gestión de usuarios, roles y permisos con validación de credenciales y registro de auditoría</p>
            <div class="main-right-cards">
                <div class="main-right-card">
                    <img src="/images/users.svg" alt="Gestión de Usuarios" class="main-right-card-icon">
                    <h2>Gestión de Usuarios</h2>
                    <p>Administre usuarios, roles y permisos de manera eficiente</p>
                </div>
                <div class="main-right-card">
                    <img src="/images/rols.svg" alt="Control de Roles" class="main-right-card-icon">
                    <h2>Control de Roles</h2>
                    <p>Asignación y gestión de permisos por rol</p>
                </div>
                <div class="main-right-card">
                    <img src="/images/audit.svg" alt="Registro de Auditoría" class="main-right-card-icon">
                    <h2>Registro de Auditoría</h2>
                    <p>Registro completo de accesos y operaciones</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>