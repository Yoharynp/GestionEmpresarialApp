@using Microsoft.AspNetCore.Http
@using GestionEmpresarialApp.Helpers
@{
    var username = Context.Session.GetString("Username") ?? "Usuario";
    var role     = Context.Session.GetString("Role") ?? "";
    var ctrl     = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action   = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isAdmin  = SessionPermissions.IsAdmin(Context.Session);

    bool showUsers = SessionPermissions.Has(Context.Session, "users.view")  || isAdmin;
    bool showRoles = SessionPermissions.Has(Context.Session, "roles.view")  || isAdmin;
    bool showAudit = SessionPermissions.Has(Context.Session, "audit.view")  || isAdmin;
    bool showProducts = SessionPermissions.Has(Context.Session, "products.view") || isAdmin;
    bool showClients = SessionPermissions.Has(Context.Session, "clients.view") || isAdmin;
}

<aside class="sidebar" id="sidebar">
    <div class="sidebar-left-accent"></div>

    <div class="sidebar-header">
        <h4>Control de Acceso</h4>
    </div>

    <nav class="sidebar-nav">
        <a href="@Url.Action("Index", "Home")"
           class="nav-btn @(ctrl == "Home" && action == "Index" ? "active" : "")">
            <div class="nav-btn-accent"></div>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M4.5 10.5V21h5v-6h5v6h5V10.5" />
            </svg>
            Panel Principal
        </a>

        @if (showUsers)
        {
            <a href="@Url.Action("Index", "Users")"
               class="nav-btn @(ctrl == "Users" ? "active" : "")">
                <div class="nav-btn-accent"></div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                </svg>
                Usuarios
            </a>
        }

        @if (showRoles)
        {
            <a href="@Url.Action("Index", "Roles")"
               class="nav-btn @(ctrl == "Roles" ? "active" : "")">
                <div class="nav-btn-accent"></div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
                Roles y Permisos
            </a>
        }

        @if (showProducts)
        {
            <a href="@Url.Action("Index", "Products")"
               class="nav-btn @(ctrl == "Products" ? "active" : "")">
                <div class="nav-btn-accent"></div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m16.5 0a48.108 48.108 0 00-16.5 0m16.5 0v-1.5c0-1.012-.609-1.934-1.55-2.316a48.56 48.56 0 00-14.9 0C5.34 3.066 4.75 3.988 4.75 5v1.5m16.5 0v10a2.25 2.25 0 01-2.25 2.25h-11.5A2.25 2.25 0 014.75 17V7m16.5 0H4.75" />
                </svg>
                Productos
            </a>
        }
        @if (showClients)
        {
            <a href="@Url.Action("Index", "Clients")"
               class="nav-btn @(ctrl == "Clients" ? "active" : "")">
                <div class="nav-btn-accent"></div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0    0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />         
              </svg>
                Clientes
            </a>
        }

        @if (showAudit)
        {
            <a href="@Url.Action("Index", "Audit")"
               class="nav-btn @(ctrl == "Audit" ? "active" : "")">
                <div class="nav-btn-accent"></div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
                </svg>
                Logs de Acceso
            </a>
        }
        
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-user-card">
            <strong>@username</strong>
            <span>@role</span>
        </div>
        <a href="@Url.Action("Logout", "Account")" class="btn-logout">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
            </svg>
            Cerrar Sesión
        </a>
    </div>
</aside>
