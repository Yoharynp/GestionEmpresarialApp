@model IEnumerable<GestionEmpresarialApp.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
    bool isAdmin    = ViewBag.IsAdmin   == true;
    bool canCreate  = ViewBag.CanCreate == true;
    bool canEdit    = ViewBag.CanEdit   == true;
    bool canDelete  = ViewBag.CanDelete == true;
    string search = ViewBag.Search ?? "";
    var roles      = ViewBag.Roles as List<GestionEmpresarialApp.Models.Rol> ?? new List<GestionEmpresarialApp.Models.Rol>();
    var urlCreate  = Url.Action("Create") ?? "/Users/Create";
    var urlEdit    = Url.Action("Edit")   ?? "/Users/Edit";
    var urlIndex   = Url.Action("Index")  ?? "/Users";
}

<div class="page-top-row">
    <div class="page-header" style="margin-bottom: 0;">
        <div class="page-header-accent"></div>
        <h3>Gestión de Usuarios</h3>
        <p>Administre los usuarios del sistema</p>
    </div>
    @if (canCreate)
    {
        <button type="button" class="btn-new" onclick="openForm()">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nuevo Usuario
        </button>
    }
</div>

@if (ViewBag.FormError != null)
{
    <div class="form-error-banner">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        @ViewBag.FormError
    </div>
}

<div class="inline-form-panel" id="inline-form" style="display:none;">
    <div class="form-panel">
        <div class="form-panel-top-accent"></div>
        <div class="form-panel-header">
            <h4 class="form-panel-title" id="form-title">Nuevo Usuario</h4>
            <button type="button" class="btn-icon" onclick="closeForm()" title="Cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <form id="user-form" method="post" action="@urlCreate">
            @Html.AntiForgeryToken()
            <input type="hidden" id="form-user-id" name="UsuarioId" value="0">
            <input type="hidden" id="form-created-at" name="CreatedAt" value="">

            <div class="form-grid" style="grid-template-columns: 1fr 1fr 1fr;">
                <div class="form-group">
                    <label for="field-username">Usuario *</label>
                    <div style="position: relative;">
                        <input type="text" id="field-username" name="Username" placeholder="nombre_usuario" required>
                        <div class="field-underline"></div>
                    </div>
                    <span class="field-error" id="err-username"></span>
                </div>

                <div class="form-group">
                    <label for="field-fullname">Nombre Completo</label>
                    <div style="position: relative;">
                        <input type="text" id="field-fullname" name="FullName" placeholder="Juan Pérez">
                        <div class="field-underline"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="field-email">Email</label>
                    <div style="position: relative;">
                        <input type="email" id="field-email" name="Email" placeholder="usuario@@empresa.com">
                        <div class="field-underline"></div>
                    </div>
                    <span class="field-error" id="err-email"></span>
                </div>

                <div class="form-group" id="group-password">
                    <label for="field-password">Contraseña <span id="pass-required" style="color: var(--red-600);">*</span> <span id="pass-hint" style="font-weight:400; color: var(--gray-500);"></span></label>
                    <div style="position: relative;">
                        <input type="password" id="field-password" name="Password" placeholder="••••••••">
                        <div class="field-underline"></div>
                    </div>
                    <span class="field-error" id="err-password"></span>
                </div>

                <div class="form-group">
                    <label for="field-rol">Rol *</label>
                    <select id="field-rol" name="RolId" required>
                        @foreach (var rol in roles)
                        {
                            <option value="@rol.RolId">@rol.NombreRol</option>
                        }
                    </select>
                    <span class="field-error" id="err-rol"></span>
                </div>

                <div class="form-group">
                    <label for="field-status">Estado *</label>
                    <select id="field-status" name="Status">
                        <option value="activo">Activo</option>
                        <option value="inactivo">Inactivo</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save" id="btn-submit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V7l-4-4z M17 3v4H7V3 M7 13h10m-5-4v8" />
                    </svg>
                    <span id="btn-label">Crear Usuario</span>
                </button>
                <button type="button" class="btn-cancel" onclick="closeForm()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<div class="table-container" style="margin-top: 1.5rem;">
    <div class="table-toolbar">
        <form method="get" action="@urlIndex">
            <div class="search-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
                <input type="text" name="search" value="@search" class="search-input" placeholder="Buscar por usuario, nombre o email...">
            </div>
        </form>
    </div>

    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Creado</th>
                    @if (canEdit || canDelete)
                    {
                        <th>Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var uFullName   = u.FullName ?? string.Empty;
                    var uEmail      = u.Email    ?? string.Empty;
                    var uCreated    = u.CreatedAt.ToString("o");
                    var uCreatedFmt = u.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy");
                    var uDeleteUrl  = Url.Action("Delete", new { id = u.UsuarioId });
                    <tr>
                        <td>@u.Username</td>
                        <td>@(uFullName == string.Empty ? "-" : uFullName)</td>
                        <td style="color: var(--gray-600);">@(uEmail == string.Empty ? "-" : uEmail)</td>
                        <td>@u.Rol?.NombreRol</td>
                        <td>
                            @if (u.Status == "activo")
                            {
                                <span class="status-badge active">Activo</span>
                            }
                            else
                            {
                                <span class="status-badge inactive">Inactivo</span>
                            }
                        </td>
                        <td style="color: var(--gray-600);">@uCreatedFmt</td>
                        @if (canEdit || canDelete)
                        {
                            <td>
                                @if (canEdit)
                                {
                                    <button type="button" class="btn-table-action edit" title="Editar"
                                        onclick="openEdit(@u.UsuarioId, '@u.Username', '@uFullName', '@uEmail', @u.RolId, '@u.Status', '@uCreated')">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
                                        </svg>
                                    </button>
                                }
                                @if (canDelete)
                                {
                                    <form method="post" action="@uDeleteUrl" style="display:inline;"
                                          onsubmit="return confirm('¿Eliminar usuario @u.Username?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-table-action delete" title="Eliminar">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                            </svg>
                                        </button>
                                    </form>
                                }
                            </td>
                        }
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center; padding: 2rem; color: var(--gray-500);">Sin usuarios para mostrar.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-footer">
        Mostrando @Model.Count() usuarios
    </div>
</div>

@section Scripts {
    <script>
        var formEl       = document.getElementById('inline-form');
        var formTag      = document.getElementById('user-form');
        var titleEl      = document.getElementById('form-title');
        var btnLabel     = document.getElementById('btn-label');
        var passHint     = document.getElementById('pass-hint');
        var passRequired = document.getElementById('pass-required');
        var fieldUser    = document.getElementById('field-username');
        var isEditMode   = false;

        /* ── open/close ── */
        function openForm() {
            isEditMode = false;
            formTag.action           = '@urlCreate';
            titleEl.textContent      = 'Nuevo Usuario';
            btnLabel.textContent     = 'Crear Usuario';
            passHint.textContent     = '';
            passRequired.style.display = 'inline';

            document.getElementById('form-user-id').value    = '0';
            document.getElementById('form-created-at').value = '';
            fieldUser.value                                   = '';
            fieldUser.disabled                                = false;
            document.getElementById('field-fullname').value  = '';
            document.getElementById('field-email').value     = '';
            document.getElementById('field-password').value  = '';
            document.getElementById('field-status').value    = 'activo';
            clearErrors();
            showPanel();
        }

        function openEdit(id, username, fullName, email, rolId, status, createdAt) {
            isEditMode = true;
            formTag.action           = '@urlEdit';
            titleEl.textContent      = 'Editar Usuario';
            btnLabel.textContent     = 'Guardar Cambios';
            passHint.textContent     = '(dejar vacío para mantener)';
            passRequired.style.display = 'none';

            document.getElementById('form-user-id').value    = id;
            document.getElementById('form-created-at').value = createdAt;
            fieldUser.value                                   = username;
            fieldUser.disabled                                = false;
            document.getElementById('field-fullname').value  = fullName;
            document.getElementById('field-email').value     = email;
            document.getElementById('field-password').value  = '';
            document.getElementById('field-rol').value       = rolId;
            document.getElementById('field-status').value    = status;
            clearErrors();
            showPanel();
        }

        function showPanel() {
            formEl.style.display = 'block';
            formEl.classList.remove('panel-closing');
            formEl.classList.add('panel-open');
            formEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function closeForm() {
            formEl.classList.remove('panel-open');
            formEl.classList.add('panel-closing');
            setTimeout(() => {
                formEl.style.display = 'none';
                formEl.classList.remove('panel-closing');
            }, 350);
        }

        /* ── validation ── */
        function setError(fieldId, errId, msg) {
            var f = document.getElementById(fieldId);
            var e = document.getElementById(errId);
            if (e) e.textContent = msg;
            if (f) f.style.borderColor = msg ? 'var(--red-600)' : '';
        }

        function clearErrors() {
            ['err-username','err-email','err-password','err-rol'].forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.textContent = '';
            });
            ['field-username','field-email','field-password','field-rol'].forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.style.borderColor = '';
            });
        }

        function validateEmail(v) {
            var re = new RegExp('^[^\\s@@]+@@[^\\s@@]+\\.[^\\s@@]+$');
            return !v || re.test(v);
        }

        formTag.addEventListener('submit', function(e) {
            clearErrors();
            var ok = true;

            var username = document.getElementById('field-username').value.trim();
            if (!isEditMode && !username) {
                setError('field-username', 'err-username', 'El usuario es requerido');
                ok = false;
            } else if (!isEditMode && username.length < 3) {
                setError('field-username', 'err-username', 'Mínimo 3 caracteres');
                ok = false;
            }

            var email = document.getElementById('field-email').value.trim();
            if (email && !validateEmail(email)) {
                setError('field-email', 'err-email', 'Email inválido');
                ok = false;
            }

            var password = document.getElementById('field-password').value;
            if (!isEditMode && !password) {
                setError('field-password', 'err-password', 'La contraseña es requerida');
                ok = false;
            }

            if (!document.getElementById('field-rol').value) {
                setError('field-rol', 'err-rol', 'Seleccione un rol');
                ok = false;
            }

            if (!ok) e.preventDefault();
        });
    </script>
}
